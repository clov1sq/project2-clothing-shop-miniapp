# Application
APP_ENV=local
LOG_LEVEL=INFO
SHOP_NAME=BlueWear

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
POSTGRES_DB=project2
POSTGRES_USER=project2
POSTGRES_PASSWORD=project2_local_password
DATABASE_URL=postgresql+asyncpg://project2:project2_local_password@postgres:5432/project2

# Telegram
# BOT_TOKEN remains supported for compatibility with the deployed v2 project.
BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
MINI_APP_URL=http://localhost:5173
ADMIN_TELEGRAM_IDS=

# Session/auth
SESSION_COOKIE_NAME=p2_session
SESSION_TTL_DAYS=14
DEV_AUTH_ENABLED=true

# Media policy (v4 keeps validated external image URLs; file upload comes later)
MEDIA_MAX_SIZE_MB=10

# Frontend
VITE_API_URL=http://localhost:8000
# Compatibility with earlier deployments; VITE_API_URL has priority.
VITE_API_BASE_URL=http://localhost:8000
VITE_SHOP_NAME=BlueWear
FRONTEND_PORT=5173
